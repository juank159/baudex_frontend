            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/number/$tInvoiceNumber'),
          ),
        );

        // Act
        final result = await dataSource.getInvoiceByNumber(tInvoiceNumber);

        // Assert
        expect(result, isA<InvoiceModel>());
        expect(result.number, tInvoiceNumber);
      },
    );
  });

  group('InvoiceRemoteDataSource - getOverdueInvoices', () {
    final tOverdueInvoices = [
      InvoiceFixtures.createOverdueInvoice(id: 'inv-001'),
      InvoiceFixtures.createOverdueInvoice(id: 'inv-002'),
    ];
    final tInvoiceModels = tOverdueInvoices
        .map((e) => InvoiceModel.fromEntity(e))
        .toList();

    final tResponseData = {
      'success': true,
      'data': tInvoiceModels.map((e) => e.toJson()).toList(),
      'message': 'Overdue invoices retrieved',
    };

    test(
      'should perform GET request to /invoices/overdue',
      () async {
        // Arrange
        when(() => mockDioClient.get(any())).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/overdue'),
          ),
        );

        // Act
        await dataSource.getOverdueInvoices();

        // Assert
        verify(() => mockDioClient.get('/invoices/overdue')).called(1);
      },
    );

    test(
      'should return list of overdue InvoiceModels',
      () async {
        // Arrange
        when(() => mockDioClient.get(any())).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/overdue'),
          ),
        );

        // Act
        final result = await dataSource.getOverdueInvoices();

        // Assert
        expect(result, isA<List<InvoiceModel>>());
        expect(result.length, 2);
      },
    );
  });

  group('InvoiceRemoteDataSource - getInvoiceStats', () {
