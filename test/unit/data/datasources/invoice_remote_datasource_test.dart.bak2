// test/unit/data/datasources/invoice_remote_datasource_test.dart
import 'package:baudex_desktop/app/core/errors/exceptions.dart';
import 'package:baudex_desktop/app/core/network/dio_client.dart';
import 'package:baudex_desktop/features/invoices/data/datasources/invoice_remote_datasource.dart';
import 'package:baudex_desktop/features/invoices/data/models/create_invoice_request_model.dart';
import 'package:baudex_desktop/features/invoices/data/models/update_invoice_request_model.dart';
import 'package:baudex_desktop/features/invoices/data/models/add_payment_request_model.dart';
import 'package:baudex_desktop/features/invoices/data/models/invoice_model.dart';
import 'package:baudex_desktop/features/invoices/data/models/invoice_stats_model.dart';
import 'package:baudex_desktop/features/invoices/data/models/invoice_response_models.dart';
import 'package:baudex_desktop/features/invoices/data/models/invoice_query_models.dart';
import 'package:baudex_desktop/features/invoices/domain/entities/invoice.dart';
import 'package:baudex_desktop/features/invoices/domain/repositories/invoice_repository.dart';
import 'package:dio/dio.dart';
import 'package:flutter_test/flutter_test.dart';
import 'package:mocktail/mocktail.dart';

import '../../../fixtures/invoice_fixtures.dart';

// Mocks
class MockDioClient extends Mock implements DioClient {}

// Helper function to create invoice JSON without using toJson()
Map<String, dynamic> createInvoiceJson({
  String id = 'inv-001',
  String number = 'INV-00001',
  String customerId = 'cust-001',
  String createdById = 'user-001',
  double total = 119000.0,
}) {
  return {
    'id': id,
    'number': number,
    'date': '2024-01-01T00:00:00.000',
    'dueDate': '2024-01-15T00:00:00.000',
    'status': 'pending',
    'paymentMethod': 'cash',
    'customerId': customerId,
    'createdById': createdById,
    'subtotal': 100000.0,
    'taxPercentage': 19.0,
    'taxAmount': 19000.0,
    'discountPercentage': 0.0,
    'discountAmount': 0.0,
    'total': total,
    'paidAmount': 0.0,
    'balanceDue': total,
    'creditedAmount': 0.0,
    'items': [],
    'payments': [],
    'createdAt': '2024-01-01T00:00:00.000',
    'updatedAt': '2024-01-01T00:00:00.000',
  };
}

void main() {
  late InvoiceRemoteDataSourceImpl dataSource;
  late MockDioClient mockDioClient;

  setUp(() {
    mockDioClient = MockDioClient();
    dataSource = InvoiceRemoteDataSourceImpl(dioClient: mockDioClient);

    // Register fallback values
    registerFallbackValue(
      InvoiceQueryParams(page: 1, limit: 10),
    );
    registerFallbackValue(
      CreateInvoiceRequestModel(
        customerId: 'cust-001',
        items: [],
      ),
    );
    registerFallbackValue(
      UpdateInvoiceRequestModel(),
    );
    registerFallbackValue(
      AddPaymentRequestModel(
        amount: 100000.0,
        paymentMethod: PaymentMethod.cash.name,
      ),
    );
  });

  group('InvoiceRemoteDataSource - getInvoices', () {
    final tInvoices = InvoiceFixtures.createInvoiceEntityList(5);
    final tInvoiceModels = tInvoices
        .map((e) => InvoiceModel.fromEntity(e))
        .toList();

    final tResponseData = {
      'success': true,
      'data': List.generate(
        5,
        (index) => {
          'id': 'inv-${index + 1}',
          'number': 'INV-${(index + 1).toString().padLeft(5, '0')}',
          'date': '2024-01-01T00:00:00.000',
          'dueDate': '2024-01-15T00:00:00.000',
          'status': 'pending',
          'paymentMethod': 'cash',
          'customerId': 'cust-001',
          'createdById': 'user-001',
          'subtotal': 100000.0,
          'taxPercentage': 19.0,
          'taxAmount': 19000.0,
          'discountPercentage': 0.0,
          'discountAmount': 0.0,
          'total': 119000.0,
          'paidAmount': 0.0,
          'balanceDue': 119000.0,
          'creditedAmount': 0.0,
          'items': [],
          'payments': [],
          'createdAt': '2024-01-01T00:00:00.000',
          'updatedAt': '2024-01-01T00:00:00.000',
        },
      ),
      'meta': {
        'page': 1,
        'totalPages': 2,
        'totalItems': 10,
        'limit': 5,
        'hasNextPage': true,
        'hasPreviousPage': false,
      },
      'message': 'Invoices retrieved successfully',
    };

    test(
      'should perform GET request to /invoices with query parameters',
      () async {
        // Arrange
        final params = InvoiceQueryParams(
          page: 1,
          limit: 10,
          search: 'INV',
          status: InvoiceStatus.pending,
        );

        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices'),
          ),
        );

        // Act
        await dataSource.getInvoices(params);

        // Assert
        verify(() => mockDioClient.get(
              '/invoices',
              queryParameters: any(named: 'queryParameters'),
            )).called(1);
      },
    );

    test(
      'should return InvoiceResponseModel when status code is 200',
      () async {
        // Arrange
        final params = InvoiceQueryParams(page: 1, limit: 10);

        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices'),
          ),
        );

        // Act
        final result = await dataSource.getInvoices(params);

        // Assert
        expect(result, isA<InvoiceResponseModel>());
        expect(result.data.length, 5);
        expect(result.meta.page, 1);
      },
    );

    test(
      'should throw ServerException when status code is 404',
      () async {
        // Arrange
        final params = InvoiceQueryParams(page: 1, limit: 10);

        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenAnswer(
          (_) async => Response(
            data: {'success': false, 'message': 'Not found'},
            statusCode: 404,
            requestOptions: RequestOptions(path: '/invoices'),
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.getInvoices(params),
          throwsA(isA<ServerException>()),
        );
      },
    );

    test(
      'should throw ConnectionException on DioException with no response',
      () async {
        // Arrange
        final params = InvoiceQueryParams(page: 1, limit: 10);

        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenThrow(
          DioException(
            requestOptions: RequestOptions(path: '/invoices'),
            type: DioExceptionType.connectionTimeout,
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.getInvoices(params),
          throwsA(isA<ConnectionException>()),
        );
      },
    );
  });

  group('InvoiceRemoteDataSource - getInvoiceById', () {
    const tInvoiceId = 'inv-001';
    final tInvoice = InvoiceFixtures.createInvoiceEntity(id: tInvoiceId);
    final tInvoiceModel = InvoiceModel.fromEntity(tInvoice);

    final tResponseData = {
      'success': true,
      'data': createInvoiceJson(id: tInvoiceId),
      'message': 'Invoice retrieved successfully',
    };

    test(
      'should perform GET request to /invoices/:id',
      () async {
        // Arrange
        when(() => mockDioClient.get(any())).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act
        await dataSource.getInvoiceById(tInvoiceId);

        // Assert
        verify(() => mockDioClient.get('/invoices/$tInvoiceId')).called(1);
      },
    );

    test(
      'should return InvoiceModel when status code is 200',
      () async {
        // Arrange
        when(() => mockDioClient.get(any())).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act
        final result = await dataSource.getInvoiceById(tInvoiceId);

        // Assert
        expect(result, isA<InvoiceModel>());
        expect(result.id, tInvoiceId);
        expect(result.number, tInvoice.number);
      },
    );

    test(
      'should throw ServerException when invoice not found (404)',
      () async {
        // Arrange
        when(() => mockDioClient.get(any())).thenAnswer(
          (_) async => Response(
            data: {'success': false, 'message': 'Invoice not found'},
            statusCode: 404,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.getInvoiceById(tInvoiceId),
          throwsA(isA<ServerException>()),
        );
      },
    );
  });

