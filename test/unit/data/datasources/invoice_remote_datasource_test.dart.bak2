        expect(result.length, 3);
      },
    );
  });

  group('InvoiceRemoteDataSource - searchInvoices', () {
    const tSearchTerm = 'INV-001';
    final tInvoices = InvoiceFixtures.createInvoiceEntityList(2);
    final tInvoiceModels = tInvoices
        .map((e) => InvoiceModel.fromEntity(e))
        .toList();

    final tResponseData = {
      'success': true,
      'data': tInvoiceModels.map((e) => e.toJson()).toList(),
      'message': 'Search results',
    };

    test(
      'should perform GET request to /invoices/search with query params',
      () async {
        // Arrange
        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/search'),
          ),
        );

        // Act
        await dataSource.searchInvoices(tSearchTerm);

        // Assert
        verify(() => mockDioClient.get(
              '/invoices/search',
              queryParameters: {'term': tSearchTerm},
            )).called(1);
      },
    );

    test(
      'should return list of matching InvoiceModels',
      () async {
        // Arrange
        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/search'),
          ),
        );

        // Act
        final result = await dataSource.searchInvoices(tSearchTerm);

        // Assert
        expect(result, isA<List<InvoiceModel>>());
        expect(result.length, 2);
      },
    );
  });

  group('InvoiceRemoteDataSource - createInvoice', () {
    final tInvoice = InvoiceFixtures.createInvoiceEntity();
    final tInvoiceModel = InvoiceModel.fromEntity(tInvoice);
    final tRequest = CreateInvoiceRequestModel(
      customerId: tInvoice.customerId,
      items: [],
    );

    final tResponseData = {
      'success': true,
      'data': createInvoiceJson(),
      'message': 'Invoice created successfully',
    };

    test(
      'should perform POST request to /invoices',
      () async {
        // Arrange
        when(() => mockDioClient.post(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 201,
            requestOptions: RequestOptions(path: '/invoices'),
          ),
        );

        // Act
        await dataSource.createInvoice(tRequest);

        // Assert
        verify(() => mockDioClient.post(
              '/invoices',
              data: any(named: 'data'),
            )).called(1);
      },
    );

    test(
      'should return created InvoiceModel when status code is 201',
      () async {
        // Arrange
        when(() => mockDioClient.post(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 201,
            requestOptions: RequestOptions(path: '/invoices'),
          ),
        );

        // Act
        final result = await dataSource.createInvoice(tRequest);

        // Assert
        expect(result, isA<InvoiceModel>());
        expect(result.customerId, tInvoice.customerId);
      },
    );

    test(
      'should throw ValidationException on 400 status code',
      () async {
        // Arrange
        when(() => mockDioClient.post(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: {
              'success': false,
              'message': 'Validation failed',
              'errors': {'customerId': 'Customer not found'}
            },
            statusCode: 400,
            requestOptions: RequestOptions(path: '/invoices'),
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.createInvoice(tRequest),
          throwsA(isA<ServerException>()),
        );
      },
    );
  });

  group('InvoiceRemoteDataSource - updateInvoice', () {
    const tInvoiceId = 'inv-001';
    final tInvoice = InvoiceFixtures.createInvoiceEntity(id: tInvoiceId);
    final tInvoiceModel = InvoiceModel.fromEntity(tInvoice);
    final tRequest = UpdateInvoiceRequestModel(
      notes: 'Updated notes',
    );

    final tResponseData = {
      'success': true,
      'data': createInvoiceJson(),
      'message': 'Invoice updated successfully',
    };

    test(
      'should perform PUT request to /invoices/:id',
      () async {
        // Arrange
        when(() => mockDioClient.put(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act
        await dataSource.updateInvoice(tInvoiceId, tRequest);

        // Assert
        verify(() => mockDioClient.put(
              '/invoices/$tInvoiceId',
              data: any(named: 'data'),
            )).called(1);
      },
    );

    test(
      'should return updated InvoiceModel when status code is 200',
      () async {
        // Arrange
        when(() => mockDioClient.put(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act
        final result = await dataSource.updateInvoice(tInvoiceId, tRequest);

        // Assert
        expect(result, isA<InvoiceModel>());
        expect(result.id, tInvoiceId);
      },
    );

    test(
      'should throw ServerException when invoice not found',
      () async {
        // Arrange
        when(() => mockDioClient.put(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: {'success': false, 'message': 'Invoice not found'},
            statusCode: 404,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.updateInvoice(tInvoiceId, tRequest),
          throwsA(isA<ServerException>()),
        );
      },
    );
  });

