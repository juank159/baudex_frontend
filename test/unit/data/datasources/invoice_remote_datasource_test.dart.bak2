  group('InvoiceRemoteDataSource - addPayment', () {
    const tInvoiceId = 'inv-001';
    final tInvoice = InvoiceFixtures.createPaidInvoice(id: tInvoiceId);
    final tInvoiceModel = InvoiceModel.fromEntity(tInvoice);
    final tRequest = AddPaymentRequestModel(
      amount: 119000.0,
      paymentMethod: PaymentMethod.cash.name,
    );

    final tResponseData = {
      'success': true,
      'data': createInvoiceJson(),
      'message': 'Payment added successfully',
    };

    test(
      'should perform POST request to /invoices/:id/payments',
      () async {
        // Arrange
        when(() => mockDioClient.post(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId/payments'),
          ),
        );

        // Act
        await dataSource.addPayment(tInvoiceId, tRequest);

        // Assert
        verify(() => mockDioClient.post(
              '/invoices/$tInvoiceId/payments',
              data: any(named: 'data'),
            )).called(1);
      },
    );

    test(
      'should return updated InvoiceModel with payment',
      () async {
        // Arrange
        when(() => mockDioClient.post(
              any(),
              data: any(named: 'data'),
            )).thenAnswer(
          (_) async => Response(
            data: tResponseData,
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId/payments'),
          ),
        );

        // Act
        final result = await dataSource.addPayment(tInvoiceId, tRequest);

        // Assert
        expect(result, isA<InvoiceModel>());
        expect(result.status, InvoiceStatus.paid);
        expect(result.paidAmount, 119000.0);
      },
    );
  });

  group('InvoiceRemoteDataSource - deleteInvoice', () {
    const tInvoiceId = 'inv-001';

    test(
      'should perform DELETE request to /invoices/:id',
      () async {
        // Arrange
        when(() => mockDioClient.delete(any())).thenAnswer(
          (_) async => Response(
            data: {'success': true, 'message': 'Invoice deleted successfully'},
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act
        await dataSource.deleteInvoice(tInvoiceId);

        // Assert
        verify(() => mockDioClient.delete('/invoices/$tInvoiceId')).called(1);
      },
    );

    test(
      'should complete successfully when status code is 200',
      () async {
        // Arrange
        when(() => mockDioClient.delete(any())).thenAnswer(
          (_) async => Response(
            data: {'success': true, 'message': 'Invoice deleted successfully'},
            statusCode: 200,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act & Assert - should not throw
        await dataSource.deleteInvoice(tInvoiceId);
      },
    );

    test(
      'should throw ServerException when deletion fails',
      () async {
        // Arrange
        when(() => mockDioClient.delete(any())).thenAnswer(
          (_) async => Response(
            data: {'success': false, 'message': 'Cannot delete invoice'},
            statusCode: 400,
            requestOptions: RequestOptions(path: '/invoices/$tInvoiceId'),
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.deleteInvoice(tInvoiceId),
          throwsA(isA<ServerException>()),
        );
      },
    );
  });

  group('InvoiceRemoteDataSource - error handling', () {
    test(
      'should throw ConnectionException on network timeout',
      () async {
        // Arrange
        final params = InvoiceQueryParams(page: 1, limit: 10);

        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenThrow(
          DioException(
            requestOptions: RequestOptions(path: '/invoices'),
            type: DioExceptionType.connectionTimeout,
            message: 'Connection timeout',
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.getInvoices(params),
          throwsA(isA<ConnectionException>()),
        );
      },
    );

    test(
      'should throw ConnectionException on receive timeout',
      () async {
        // Arrange
        final params = InvoiceQueryParams(page: 1, limit: 10);

        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenThrow(
          DioException(
            requestOptions: RequestOptions(path: '/invoices'),
            type: DioExceptionType.receiveTimeout,
            message: 'Receive timeout',
          ),
        );

        // Act & Assert
        expect(
          () => dataSource.getInvoices(params),
          throwsA(isA<ConnectionException>()),
        );
      },
    );

    test(
      'should throw ServerException on unexpected errors',
      () async {
        // Arrange
        final params = InvoiceQueryParams(page: 1, limit: 10);

        when(() => mockDioClient.get(
              any(),
              queryParameters: any(named: 'queryParameters'),
            )).thenThrow(Exception('Unexpected error'));

        // Act & Assert
        expect(
          () => dataSource.getInvoices(params),
          throwsA(isA<ServerException>()),
        );
      },
    );
  });
}
