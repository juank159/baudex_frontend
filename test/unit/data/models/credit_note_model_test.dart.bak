  group('CreditNotePaginatedResponseModel', () {
    test('should parse paginated response correctly', () {
      // Arrange
      final json = {
        'data': [
          {
            'id': 'cn-001',
            'number': 'CN-001',
            'date': '2024-01-05T00:00:00.000',
            'type': 'PARTIAL',
            'reason': 'RETURNED_GOODS',
            'status': 'DRAFT',
            'subtotal': 50000.0,
            'taxPercentage': 19.0,
            'taxAmount': 9500.0,
            'total': 59500.0,
            'invoiceId': 'inv-001',
            'customerId': 'cust-001',
            'createdById': 'user-001',
            'items': [],
            'createdAt': '2024-01-05T00:00:00.000',
            'updatedAt': '2024-01-05T00:00:00.000',
          }
        ],
        'meta': {
          'page': 1,
          'limit': 10,
          'totalItems': 1,
          'totalPages': 1,
          'hasNextPage': false,
          'hasPreviousPage': false,
        },
      };

      // Act
      final result = CreditNotePaginatedResponseModel.fromJson(json);

      // Assert
      expect(result.data, isA<List<CreditNoteModel>>());
      expect(result.data.length, 1);
      expect(result.meta, isA<Map<String, dynamic>>());
      expect(result.meta['page'], 1);
      expect(result.meta['totalItems'], 1);
    });
  });
}
